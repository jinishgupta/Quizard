# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# Database Configuration (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Orange ID Authentication (Bedrock Passport)
BEDROCK_TENANT_ID=your-tenant-id
BEDROCK_SUBSCRIPTION_KEY=your-subscription-key
BEDROCK_BASE_URL=https://api.bedrockpassport.com
BEDROCK_AUTH_CALLBACK_URL=http://localhost:5173/auth/callback

# Orange Game Pass Integration
ORANGE_TENANT_CODE=orange-xxxxxxx
ORANGE_GAME_PASS_API_URL=https://app.orangeweb3.com/api/games/passes

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-exp

# League Configuration
LEAGUE_RESET_DAY=0
LEAGUE_RESET_HOUR=0

# Credit Costs
CREDITS_STANDARD_ROUND=12
CREDITS_HINT_ELIMINATE=6
CREDITS_HINT_CLUE=6
CREDITS_HINT_FIRST_LETTER=6
CREDITS_EXPLANATION_PACK=15
CREDITS_BONUS_ROUND=10
CREDITS_CUSTOM_QUIZ=30
CREDITS_SEND_CHALLENGE=10
CREDITS_EARLY_DIGEST=10
